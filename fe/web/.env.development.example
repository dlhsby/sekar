# SEKAR Web Dashboard - Development Environment
# Copy this file to .env.local for local development

# =============================================================================
# API Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# =============================================================================
# Maps Configuration
# =============================================================================
# Use development Mapbox token (create separate token for dev)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-development-mapbox-token-here

# =============================================================================
# Application Metadata
# =============================================================================
NEXT_PUBLIC_APP_NAME=SEKAR (Development)
NEXT_PUBLIC_APP_VERSION=2.0.0-dev

# =============================================================================
# Feature Flags (Development)
# =============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=true

# =============================================================================
# Analytics (Disabled in Development)
# =============================================================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# =============================================================================
# Error Tracking (Optional for Development)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# =============================================================================
# Application Settings
# =============================================================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# Security (Development)
# =============================================================================
# Simple secret for development (never use in production!)
SESSION_SECRET=dev-secret-for-local-testing-only

# =============================================================================
# Development Tools
# =============================================================================
# Enable React Strict Mode (helps identify issues)
# NEXT_PUBLIC_STRICT_MODE=true

# Enable source maps for debugging
# GENERATE_SOURCEMAP=true

# =============================================================================
# Database (if connecting directly from Next.js - usually via backend)
# =============================================================================
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sekar_db

# =============================================================================
# Quick Start Instructions
# =============================================================================
# 1. Copy this file: cp .env.development.example .env.local
# 2. Update NEXT_PUBLIC_MAPBOX_TOKEN with your development token
# 3. Ensure backend is running on http://localhost:3000
# 4. Run: npm run dev
# 5. Open: http://localhost:3001
