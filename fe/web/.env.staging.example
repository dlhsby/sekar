# SEKAR Web Dashboard - Staging Environment
#
# Quick Start:
#   cp .env.staging.example .env.staging
#   # Update SESSION_SECRET, Mapbox token, Sentry DSN, and GA ID
#   npm run build && npm start
#
# Staging mirrors production settings with staging-specific URLs.
# Test all changes here before deploying to production.

# =============================================================================
# API Configuration
# =============================================================================
# Staging backend URL (WITHOUT /api/v1 — the client appends it automatically).
# UAT runs over HTTPS via Caddy auto-HTTPS (bare hostnames in infra/Caddyfile.staging).
# NOTE: these NEXT_PUBLIC_* are baked into the bundle at BUILD time — the CI workflow
# (.github/workflows/deploy-staging.yml) passes them as docker build-args.
NEXT_PUBLIC_API_URL=https://api.sekar.wahyutrip.com

# API Version
NEXT_PUBLIC_API_VERSION=v1

# WebSocket URL for real-time updates (wss:// over HTTPS)
NEXT_PUBLIC_WS_URL=wss://api.sekar.wahyutrip.com

# =============================================================================
# Maps Configuration
# =============================================================================
# Mapbox Access Token (public pk.*). Stored as the GitHub Actions secret
# NEXT_PUBLIC_MAPBOX_TOKEN. Get from: https://account.mapbox.com/access-tokens/
# Recommended URL restriction: https://sekar.wahyutrip.com/*
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-staging-mapbox-token-here

# Google Maps JS key (browser/referer-restricted) for the master-data coordinate
# picker + display modal. Build-time, preferred over the backend GET /config/maps
# fallback. Restrict by HTTP referrer (https://sekar.wahyutrip.com/*). Same key as
# backend GOOGLE_MAPS_API_KEY + the mobile app (enable Maps JavaScript API).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-staging-google-maps-key-here

# =============================================================================
# Application Metadata
# =============================================================================
NEXT_PUBLIC_APP_NAME=SEKAR
NEXT_PUBLIC_APP_VERSION=2.0.0

# =============================================================================
# Feature Flags (Staging — mirrors production)
# =============================================================================
# PWA service worker registration. OFF on staging until the SW update flow is
# device-tested — a stuck "waiting" worker otherwise re-shows the update toast on
# every load. (HTTPS prerequisite is satisfied; flip to true once update UX is verified.)
NEXT_PUBLIC_FEATURE_PWA=false
# Web Push VAPID public key (npx web-push generate-vapid-keys). Required for
# admin push subscriptions; private key stays on the backend.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=REPLACE-WITH-VAPID-PUBLIC-KEY

# Google Analytics tracking
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Sentry error reporting
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# React DevTools (disabled in staging)
NEXT_PUBLIC_ENABLE_DEVTOOLS=false

# Verbose logging (disabled in staging)
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# =============================================================================
# Analytics (Staging)
# =============================================================================
# Google Analytics Measurement ID (GA4)
# Use separate GA property for staging to avoid polluting production data
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-STAGING-ID

# =============================================================================
# Error Tracking (Staging)
# =============================================================================
# Sentry is wired (src/instrumentation*.ts + global-error.tsx). It STAYS DORMANT
# until NEXT_PUBLIC_SENTRY_DSN is set — leave EMPTY to disable cleanly (an invalid
# placeholder would make Sentry.init fail in the browser).
# Get a DSN from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
# Client trace sampling (defaults to 0.1 when unset).
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Source-map upload at build time (optional). withSentryConfig only uploads when
# SENTRY_AUTH_TOKEN is present — set all three as GitHub Actions secrets in CI.
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=sekar-web
# SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# =============================================================================
# Application Settings
# =============================================================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# Security (Staging)
# =============================================================================
# Generate a strong random secret
# Generate with: openssl rand -base64 32
# Store in environment variables or secrets manager
SESSION_SECRET=REPLACE-WITH-STRONG-RANDOM-SECRET
# Auth cookies carry the Secure flag — required now that staging is HTTPS.
# (Keep this false only on a plain-HTTP deploy, or login cookies get dropped.)
NEXT_PUBLIC_SECURE_COOKIES=true

# =============================================================================
# Performance Monitoring (Optional)
# =============================================================================
# Vercel Analytics (automatically enabled if deployed on Vercel)
# No additional configuration needed

# New Relic APM (optional)
# NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
# NEW_RELIC_APP_NAME=SEKAR Web Dashboard (Staging)

# =============================================================================
# Build Settings (Staging)
# =============================================================================
# DO NOT skip type checking in staging
SKIP_TYPE_CHECK=false

# DO NOT skip ESLint in staging
SKIP_ESLINT=false

# Enable production optimizations
# NEXT_PRIVATE_STANDALONE=true

# =============================================================================
# Logging (Optional)
# =============================================================================
# CloudWatch Log Group (if using AWS)
# LOG_GROUP=/aws/ecs/sekar-web-staging
# LOG_STREAM_PREFIX=staging

# =============================================================================
# CDN & Static Assets (Optional)
# =============================================================================
# CloudFront Distribution Domain (if using AWS CloudFront)
# NEXT_PUBLIC_CDN_URL=https://d1234567890abc.cloudfront.net

# S3 Bucket for static assets (if using AWS S3)
# AWS_S3_BUCKET=sekar-web-static-assets-staging
# AWS_REGION=ap-southeast-1

# =============================================================================
# Staging Deployment Checklist
# =============================================================================
# [ ] Replace all placeholder values with real staging values
# [ ] Generate strong SESSION_SECRET (openssl rand -base64 32)
# [ ] Configure Mapbox token with URL restrictions for staging domain
# [ ] Set up Google Analytics with staging property
# [ ] Configure Sentry error tracking
# [ ] Verify all API URLs use HTTPS (not HTTP)
# [ ] Test WebSocket connection (wss:// protocol)
# [ ] Verify CORS settings in backend allow staging domain
# [ ] Test all environment variables before deploying to production

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit .env.staging to version control
# 2. NEXT_PUBLIC_* variables are exposed to the browser (client-side)
# 3. Non-NEXT_PUBLIC variables are only available server-side
# 4. Test all changes in staging before deploying to production
