# SEKAR Web Dashboard - Production Environment
#
# Quick Start:
#   cp .env.production.example .env.production
#   # Replace ALL placeholder values with real production values
#   # Generate secrets: openssl rand -base64 32
#   npm run build && npm start
#
# CRITICAL: Test all values in staging first before deploying to production!

# =============================================================================
# API Configuration
# =============================================================================
# Production backend URL (WITHOUT /api/v1 — the client appends it automatically)
NEXT_PUBLIC_API_URL=https://api.sekar.wahyutrip.com

# API Version
NEXT_PUBLIC_API_VERSION=v1

# WebSocket URL for real-time updates (wss:// for production HTTPS)
NEXT_PUBLIC_WS_URL=wss://api.sekar.wahyutrip.com

# =============================================================================
# Maps Configuration
# =============================================================================
# CRITICAL: Google Maps is the sole map provider. Use a production key with
# HTTP-referrer restrictions (https://sekar.wahyutrip.com/*) and the Maps
# JavaScript API + Geocoding API enabled. Same key as backend GOOGLE_MAPS_API_KEY.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-production-google-maps-key-here

# =============================================================================
# Application Metadata
# =============================================================================
NEXT_PUBLIC_APP_NAME=SEKAR
NEXT_PUBLIC_APP_VERSION=2.0.0

# =============================================================================
# Feature Flags (Production)
# =============================================================================
# PWA service worker registration
NEXT_PUBLIC_FEATURE_PWA=true
# Web Push VAPID public key (npx web-push generate-vapid-keys). Required for
# admin push subscriptions; private key stays on the backend.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=REPLACE-WITH-VAPID-PUBLIC-KEY

# Google Analytics tracking
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Sentry error reporting
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# React DevTools (MUST be disabled in production)
NEXT_PUBLIC_ENABLE_DEVTOOLS=false

# Verbose logging (MUST be disabled in production)
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# =============================================================================
# Analytics (Production)
# =============================================================================
# Google Analytics Measurement ID (GA4)
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# Error Tracking (Production)
# =============================================================================
# Sentry DSN for production error tracking
# Get from: https://sentry.io/settings/projects/
# CRITICAL: Configure release tracking and source maps upload
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Sentry Auth Token (for uploading source maps in CI/CD)
# Keep this secret! Only use in GitHub Actions secrets
# SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# =============================================================================
# Application Settings
# =============================================================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# Security (Production)
# =============================================================================
# CRITICAL: Generate a strong random secret
# Generate with: openssl rand -base64 32
# Store in AWS Secrets Manager or environment variables
# NEVER commit this to git!
SESSION_SECRET=REPLACE-WITH-STRONG-RANDOM-SECRET-FROM-SECRETS-MANAGER
# Auth cookies must be secure over HTTPS in staging/production.
NEXT_PUBLIC_SECURE_COOKIES=true

# =============================================================================
# Performance Monitoring (Production)
# =============================================================================
# Vercel Analytics (automatically enabled if deployed on Vercel)
# No additional configuration needed

# New Relic APM (optional)
# NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
# NEW_RELIC_APP_NAME=SEKAR Web Dashboard

# =============================================================================
# Build Settings (Production)
# =============================================================================
# DO NOT skip type checking in production
SKIP_TYPE_CHECK=false

# DO NOT skip ESLint in production
SKIP_ESLINT=false

# Enable production optimizations
# NEXT_PRIVATE_STANDALONE=true

# =============================================================================
# Logging (Production)
# =============================================================================
# CloudWatch Log Group (if using AWS)
# LOG_GROUP=/aws/ecs/sekar-web
# LOG_STREAM_PREFIX=production

# =============================================================================
# Database (if connecting directly - not recommended for web)
# =============================================================================
# Use backend API instead of direct database connection
# If you MUST connect directly, use connection pooling and read replicas
# DATABASE_URL=postgresql://user:password@rds-endpoint:5432/sekar_db

# =============================================================================
# CDN & Static Assets (Production)
# =============================================================================
# CloudFront Distribution Domain (if using AWS CloudFront)
# NEXT_PUBLIC_CDN_URL=https://d1234567890abc.cloudfront.net

# S3 Bucket for static assets (if using AWS S3)
# AWS_S3_BUCKET=sekar-web-static-assets
# AWS_REGION=ap-southeast-1

# =============================================================================
# Security Headers (configured in next.config.ts)
# =============================================================================
# Additional CSP directives can be added via next.config.ts
# See docs/deployment-guide.md for security configuration

# =============================================================================
# Production Deployment Checklist
# =============================================================================
# [ ] Replace all placeholder values with real production values
# [ ] Generate strong SESSION_SECRET (openssl rand -base64 32)
# [ ] Configure Google Maps API key with URL restrictions
# [ ] Set up Google Analytics tracking
# [ ] Configure Sentry error tracking with release tracking
# [ ] Verify all API URLs use HTTPS (not HTTP)
# [ ] Test WebSocket connection (wss:// protocol)
# [ ] Configure CloudWatch or New Relic monitoring
# [ ] Set up CloudFront CDN for static assets
# [ ] Enable AWS WAF for DDoS protection
# [ ] Configure auto-scaling policies in ECS
# [ ] Set up automated database backups
# [ ] Test rollback procedures
# [ ] Configure Slack/PagerDuty alerts for critical errors
# [ ] Verify CORS settings in backend allow web dashboard domain
# [ ] Test all environment variables in staging first
# [ ] Document all secrets in team password manager
# [ ] Set up secret rotation policies in AWS Secrets Manager
# [ ] Enable CloudTrail audit logging
# [ ] Configure RDS read replicas for scalability
# [ ] Test disaster recovery procedures

# =============================================================================
# Production Support Contacts
# =============================================================================
# DevOps Team: devops@dlhsurabaya.go.id
# Development Team: dev@dlhsurabaya.go.id
# On-Call Rotation: See PagerDuty schedule

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit .env.production to version control
# 2. NEXT_PUBLIC_* variables are exposed to the browser (client-side)
# 3. Non-NEXT_PUBLIC variables are only available server-side
# 4. Restart the server after changing variables
# 5. Test all environment variables in staging first
