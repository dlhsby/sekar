# SEKAR Web Dashboard - Environment Variables
#
# Quick Start (Local Development):
#   cp .env.example .env
#   # Edit .env and add your NEXT_PUBLIC_MAPBOX_TOKEN
#   npm run dev
#
# Production Deployment:
#   cp .env.example .env.production
#   # Update all values marked with [PRODUCTION] below
#   # Generate secrets: openssl rand -base64 32

# =============================================================================
# API Configuration
# =============================================================================
# Backend API URL (without /api path)
# [LOCAL] http://localhost:3000
# [PRODUCTION] https://api.sekar.dlhsurabaya.go.id
NEXT_PUBLIC_API_URL=http://localhost:3000

# API Version
NEXT_PUBLIC_API_VERSION=v1

# WebSocket URL for real-time updates
# [LOCAL] ws://localhost:3000
# [PRODUCTION] wss://api.sekar.dlhsurabaya.go.id (use wss:// for secure WebSocket)
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# =============================================================================
# Maps Configuration
# =============================================================================
# Mapbox Access Token
# Get from: https://account.mapbox.com/access-tokens/
# [PRODUCTION] Configure URL restrictions: https://sekar.dlhsurabaya.go.id/*
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token-here

# =============================================================================
# Application Metadata
# =============================================================================
NEXT_PUBLIC_APP_NAME=SEKAR
NEXT_PUBLIC_APP_VERSION=0.0.1

# =============================================================================
# Feature Flags
# =============================================================================
# [LOCAL] false | [PRODUCTION] true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# [LOCAL] false | [PRODUCTION] true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false

# [LOCAL] true | [PRODUCTION] false
NEXT_PUBLIC_ENABLE_DEVTOOLS=true

# [LOCAL] false/true | [PRODUCTION] false
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# =============================================================================
# Analytics (Optional)
# =============================================================================
# Google Analytics Measurement ID (GA4)
# Get from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# =============================================================================
# Error Tracking (Optional)
# =============================================================================
# Sentry DSN for error tracking
# Get from https://sentry.io/settings/projects/
# Format: https://xxxxx@sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=

# Sentry Environment
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# =============================================================================
# Application Settings
# =============================================================================
# Node environment (development, production, test)
# Automatically set by Next.js, but can be overridden
NODE_ENV=development

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# Security
# =============================================================================
# Session secret for JWT validation
# [LOCAL] Use the default below
# [PRODUCTION] Generate with: openssl rand -base64 32
SESSION_SECRET=dev-secret-for-local-only

# =============================================================================
# Build Settings (Optional)
# =============================================================================
# Skip type checking during builds (not recommended for production)
# SKIP_TYPE_CHECK=false

# Skip ESLint during builds (not recommended for production)
# SKIP_ESLINT=false

# =============================================================================
# Production Deployment Checklist
# =============================================================================
# [ ] Update NEXT_PUBLIC_API_URL to production URL (https://)
# [ ] Update NEXT_PUBLIC_WS_URL to secure WebSocket (wss://)
# [ ] Generate SESSION_SECRET: openssl rand -base64 32
# [ ] Set up Mapbox token with URL restrictions
# [ ] Enable analytics: NEXT_PUBLIC_ENABLE_ANALYTICS=true
# [ ] Enable error tracking: NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
# [ ] Disable dev tools: NEXT_PUBLIC_ENABLE_DEVTOOLS=false
# [ ] Disable debug logs: NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false
# [ ] Configure Sentry DSN and GA_MEASUREMENT_ID
# [ ] Test all environment variables in staging first
# [ ] Never commit .env or .env.production to git

# =============================================================================
# Important Notes
# =============================================================================
# - NEXT_PUBLIC_* variables are exposed to the browser (client-side)
# - Non-NEXT_PUBLIC variables are only available server-side
# - Restart dev server after changing variables: npm run dev
# - Copy this file: cp .env.example .env (for local) or .env.production (for prod)
