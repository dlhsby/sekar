# SEKAR Mobile — STAGING / UAT template (copy to .env.staging; .env.staging is gitignored)
#
# Mobile reads ONE env file, selected by ENVFILE in babel.config.js (default .env.local).
# Build against deployed staging with:
#   ENVFILE=.env.staging npm start -- --reset-cache
#   ENVFILE=.env.staging npm run android
# Values are inlined at bundle time — ALWAYS --reset-cache after switching files.

# ========================================
# API — deployed staging (no TLS yet → http://)
# ========================================
# App builds: {API_BASE_URL}/api/{API_VERSION} → http://api.sekar.wahyutrip.com/api/v1
# Android cleartext HTTP is allowed (AndroidManifest usesCleartextTraffic="true").
API_BASE_URL=http://api.sekar.wahyutrip.com
API_VERSION=v1

APP_ENV=staging

# ========================================
# Google Maps (Android map screens only)
# ========================================
# Required for supervisor/monitoring map; other flows work without it.
# Restrict the key to package com.wahyutrip.sekar. Rotate the previously-exposed key before reuse.
GOOGLE_MAPS_API_KEY=

# ========================================
# Location tracking
# ========================================
LOCATION_MIN_INTERVAL_SECONDS=10
LOCATION_MAX_INTERVAL_SECONDS=60
LOCATION_DISTANCE_FILTER_METERS=0
LOCATION_BATCH_UPLOAD_SIZE=20
LOCATION_MAX_BUFFER_SIZE=100
GPS_TIMEOUT_SECONDS=10

# ========================================
# Sync
# ========================================
SYNC_INTERVAL_SECONDS=300
MAP_REFRESH_INTERVAL_SECONDS=120

# ========================================
# Media
# ========================================
MAX_IMAGE_WIDTH=800
MAX_VIDEO_SIZE_MB=50
MAX_VIDEO_DURATION_SECONDS=30

# ========================================
# Phase 3 — Monitoring v2 / feature flags
# ========================================
CLUSTER_MARKERS_V2_ENABLED=false
MONITORING_CLUSTER_ZOOM_THRESHOLD=12
FEATURE_PLANTS_ENABLED=false
FEATURE_PRUNING_REQUESTS_ENABLED=false
FEATURE_PLANT_SEEDS_ENABLED=false

# ========================================
# Support hotline
# ========================================
SUPPORT_HOTLINE_WHATSAPP=081200000000
SUPPORT_HOTLINE_PHONE=0317788990

# ========================================
# Crash reporting (Sentry) — set a mobile DSN to enable in staging
# ========================================
SENTRY_DSN_MOBILE=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
