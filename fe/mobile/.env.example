# SEKAR Mobile App - Environment Configuration

# ========================================
# API Configuration
# ========================================
#
# API_BASE_URL: Host URL (without /api path)
# API_VERSION: API version string
#
# The app constructs: {API_BASE_URL}/api/{API_VERSION}
# Example: http://10.0.2.2:3000 + v1 = http://10.0.2.2:3000/api/v1
#
# Common hosts:
# - Android Emulator: http://10.0.2.2:3000
# - Physical Device: http://YOUR_COMPUTER_IP:3000
# - iOS Simulator: http://localhost:3000
# - Production: https://api.sekar.dlhsurabaya.go.id

# Development (Android Emulator)
API_BASE_URL=http://10.0.2.2:3000
API_VERSION=v1

# For Production (uncomment and use for production builds)
# API_BASE_URL=https://api.sekar.dlhsurabaya.go.id
# API_VERSION=v1

# ========================================
# Google Maps Configuration
# ========================================
#
# Google Maps API Key (required for supervisor map features)
# Get your key from: https://console.cloud.google.com/google/maps-apis
#
# For production:
# 1. Create a production API key
# 2. Restrict it to your app's package name (com.sekarapp)
# 3. Enable Maps SDK for Android
# 4. Set the key here

GOOGLE_MAPS_API_KEY=

# ========================================
# App Environment
# ========================================
#
# Valid values: development, staging, production
# This affects logging, error reporting, and feature flags
#
# - development: Full logging, debug features enabled
# - staging: Limited logging, some debug features
# - production: Minimal logging, all debug features disabled

APP_ENV=development

# For Production builds, use:
# APP_ENV=production

# ========================================
# Location Tracking Configuration
# ========================================
#
# Controls how frequently location is captured during active shifts
# Values are in seconds

# Minimum interval between location captures (default: 10 seconds)
LOCATION_MIN_INTERVAL_SECONDS=10

# Maximum interval between location captures (default: 60 seconds)
LOCATION_MAX_INTERVAL_SECONDS=60

# Distance filter in meters - 0 means track even when stationary (default: 0)
LOCATION_DISTANCE_FILTER_METERS=0

# Batch upload size - upload after this many locations (default: 20)
LOCATION_BATCH_UPLOAD_SIZE=20

# Maximum buffer size before forcing upload (default: 100)
LOCATION_MAX_BUFFER_SIZE=100

# GPS timeout in seconds (default: 10)
GPS_TIMEOUT_SECONDS=10

# ========================================
# Sync Configuration
# ========================================
#
# Controls offline sync behavior

# Sync interval in seconds (default: 300 = 5 minutes)
SYNC_INTERVAL_SECONDS=300

# Map refresh interval in seconds (default: 120 = 2 minutes)
MAP_REFRESH_INTERVAL_SECONDS=120

# ========================================
# Media Configuration
# ========================================
#
# Controls image/video compression and limits

# Maximum image width in pixels (default: 800)
MAX_IMAGE_WIDTH=800

# Maximum video size in MB (default: 50)
MAX_VIDEO_SIZE_MB=50

# Maximum video duration in seconds (default: 30)
MAX_VIDEO_DURATION_SECONDS=30

# ========================================
# Phase 3 — Monitoring v2
# ========================================
#
# Cluster markers and real-time monitoring (WebSocket-driven)

# Enable clustered marker rendering (v2 implementation with Redis projector)
CLUSTER_MARKERS_V2_ENABLED=false

# Zoom threshold at which to show individual markers instead of clusters
MONITORING_CLUSTER_ZOOM_THRESHOLD=12

# ========================================
# Phase 3 — Feature flags
# ========================================
#
# Gradual rollout controls for Phase 3 features

# Plants management and monitoring
FEATURE_PLANTS_ENABLED=false

# Pruning request intake (staff_kecamatan role)
FEATURE_PRUNING_REQUESTS_ENABLED=false

# Plant seed inventory system
FEATURE_PLANT_SEEDS_ENABLED=false

# ========================================
# Production Release Checklist
# ========================================
#
# Before building for production:
# [ ] Set API_BASE_URL to production URL (host only, no /api path)
# [ ] Set API_VERSION to current version (e.g., v1)
# [ ] Set APP_ENV to production
# [ ] Set GOOGLE_MAPS_API_KEY to production key (restricted to com.sekarapp)
# [ ] Review location tracking intervals for production use
# [ ] Verify all API endpoints are accessible
# [ ] Test with production backend
# [ ] Review and remove any debug code
# [ ] Update version in android/app/build.gradle
# [ ] Generate release keystore (see android/gradle.properties.example)
# [ ] Build and test release APK before distributing
