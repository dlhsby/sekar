# SEKAR Mobile App - Environment Configuration

# ========================================
# API Base URL Configuration
# ========================================
#
# Development URLs (includes /api/v1 prefix):
# - Android Emulator: http://10.0.2.2:3000/api/v1
# - Physical Device: http://YOUR_COMPUTER_IP:3000/api/v1 (e.g., http://192.168.1.100:3000/api/v1)
# - iOS Simulator: http://localhost:3000/api/v1
#
# Production URL:
# - Production: https://api.sekar.dlhsurabaya.go.id/api/v1
#
# Note: The base URL includes the /api/v1 versioning path

# For Development (Android Emulator)
API_BASE_URL=http://10.0.2.2:3000/api/v1

# For Production (uncomment and use this for production builds)
# API_BASE_URL=https://api.sekar.dlhsurabaya.go.id/api/v1

# ========================================
# Google Maps Configuration
# ========================================
#
# Google Maps API Key (required for supervisor map features)
# Get your key from: https://console.cloud.google.com/google/maps-apis
#
# For production:
# 1. Create a production API key
# 2. Restrict it to your app's package name (com.sekarapp)
# 3. Enable Maps SDK for Android
# 4. Set the key here

GOOGLE_MAPS_API_KEY=

# ========================================
# App Environment
# ========================================
#
# Valid values: development, staging, production
# This affects logging, error reporting, and feature flags
#
# - development: Full logging, debug features enabled
# - staging: Limited logging, some debug features
# - production: Minimal logging, all debug features disabled

APP_ENV=development

# For Production builds, use:
# APP_ENV=production

# ========================================
# Production Release Checklist
# ========================================
#
# Before building for production:
# [ ] Set API_BASE_URL to production URL
# [ ] Set APP_ENV to production
# [ ] Set GOOGLE_MAPS_API_KEY to production key (restricted to com.sekarapp)
# [ ] Verify all API endpoints are accessible
# [ ] Test with production backend
# [ ] Review and remove any debug code
# [ ] Update version in android/app/build.gradle
# [ ] Generate release keystore (see android/gradle.properties.example)
# [ ] Build and test release APK before distributing
