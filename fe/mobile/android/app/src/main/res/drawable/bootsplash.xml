<!-- Cold-start window background: sage canvas + centered icon.
     Matches the Android 12 OS splash exactly (stage 1 = stage 2 = icon on sage).
     SEKAR wordmark + tagline appear in WL-1 (SplashSlide.tsx) after JS loads.
     windowSplashScreenBrandingImage is NOT used — Android always stretches it
     to fill the screen width and positions it at a device-specific offset,
     making pixel-identical matching between stages impossible. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/bootsplash_background" />
    <item
        android:gravity="center"
        android:width="200dp"
        android:height="200dp"
        android:drawable="@drawable/splash_icon" />
</layer-list>
