            <group android:rotation="135"><path android:pathData="M 0 -14 Q 18 -38 0 -42 Q -14 -38 0 -14 Z" android:fillColor="#7FBC8C" android:strokeColor="#1C1917" android:strokeWidth="5" android:strokeLineJoin="round" /></group>
            <group android:rotation="180"><path android:pathData="M 0 -14 Q 18 -38 0 -42 Q -14 -38 0 -14 Z" android:fillColor="#7FBC8C" android:strokeColor="#1C1917" android:strokeWidth="5" android:strokeLineJoin="round" /></group>
