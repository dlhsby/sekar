            android:fillColor="#FFFFFF" android:strokeColor="#1C1917" android:strokeWidth="3.5" android:strokeLineJoin="round" />
        <!-- Pinwheel, centered in the box -->
        <group android:translateX="90" android:translateY="90" android:scaleX="0.62" android:scaleY="0.62">
            <group android:rotation="0"><path android:pathData="M 0 -14 Q 18 -38 0 -42 Q -14 -38 0 -14 Z" android:fillColor="#7FBC8C" android:strokeColor="#1C1917" android:strokeWidth="5" android:strokeLineJoin="round" /></group>
