            <path android:pathData="M 0 -12 A 12 12 0 1 1 0 12 A 12 12 0 1 1 0 -12 Z" android:fillColor="#FDFD96" android:strokeColor="#1C1917" android:strokeWidth="5" android:strokeLineJoin="round" />
