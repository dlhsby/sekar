<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 12+ (API 31+): three-stage launch, all visually identical:
          1. OS system splash  — icon + branding image (windowSplashScreen*)
          2. Window background — full artwork (windowBackground = bootsplash)
          3. WL-1 JS splash    — full branding (SplashSlide.tsx)

        windowBackground MUST be the full artwork (not just the color) so there
        is no bare-sage flash between the OS splash exit animation and React
        Native's first frame.
    -->
    <style name="BootTheme" parent="AppTheme">
        <!-- Full artwork shown as window background during RN load — no green flash. -->
        <item name="android:windowBackground">@drawable/bootsplash</item>
        <item name="android:statusBarColor">@color/bootsplash_background</item>
        <!-- OS system splash: icon centered + branding (SEKAR + tagline) at bottom. -->
        <item name="android:windowSplashScreenBackground">@color/bootsplash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/bootsplash_background</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/splash_branding</item>
    </style>
</resources>
