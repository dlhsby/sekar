{
  "name": "SEKAR",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "cd android && ./gradlew assembleDebug -x installDebug && cd .. && DEVICE=$(adb devices 2>&1 | sed -n '2p' | awk '{print $1}') && adb -s \"$DEVICE\" install -r android/app/build/outputs/apk/debug/app-debug.apk && adb -s \"$DEVICE\" reverse tcp:8081 tcp:8081 && adb -s \"$DEVICE\" shell am start -n com.wahyutrip.sekar/.MainActivity",
    "android:clean": "cd android && ./gradlew clean && cd .. && npm run android",
    "android:rebuild": "rm -rf android/app/build && npm run android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit"
  },
