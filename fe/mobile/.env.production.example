# SEKAR Mobile — PRODUCTION template (copy to .env.production, then encrypt)
#
# Production API is the on-prem (pemkot) server. After filling real values:
#   npm run env:encrypt          # encrypts .env.staging + .env.production in place
# then commit the ENCRYPTED .env.production (secrets become `encrypted:…`).
# Build:  npm run build:android:production   (decrypts to .env.runtime at build time)
# Needs DOTENV_PRIVATE_KEY_PRODUCTION in the environment (or local .env.keys).
# See specs/deployment/encrypted-secrets.md.

# ========================================
# API — on-prem production
# ========================================
# App builds: {API_BASE_URL}/api/{API_VERSION}. Use https:// once TLS is terminated.
API_BASE_URL=https://api.sekar.example.go.id
API_VERSION=v1

APP_ENV=production

# ========================================
# Google Maps (Android map screens only)
# ========================================
# Restrict the key to package com.wahyutrip.sekar. Rotate the previously-exposed key before reuse.
GOOGLE_MAPS_API_KEY=

# ========================================
# Location tracking
# ========================================
LOCATION_MIN_INTERVAL_SECONDS=10
LOCATION_MAX_INTERVAL_SECONDS=60
LOCATION_DISTANCE_FILTER_METERS=0
LOCATION_BATCH_UPLOAD_SIZE=20
LOCATION_MAX_BUFFER_SIZE=100
GPS_TIMEOUT_SECONDS=10

# ========================================
# Sync
# ========================================
SYNC_INTERVAL_SECONDS=300
MAP_REFRESH_INTERVAL_SECONDS=120

# ========================================
# Media
# ========================================
MAX_IMAGE_WIDTH=800
MAX_VIDEO_SIZE_MB=50
MAX_VIDEO_DURATION_SECONDS=30

# ========================================
# Phase 3 — Monitoring v2 / feature flags
# ========================================
CLUSTER_MARKERS_V2_ENABLED=false
MONITORING_CLUSTER_ZOOM_THRESHOLD=12
FEATURE_PLANTS_ENABLED=false
FEATURE_PRUNING_REQUESTS_ENABLED=false
FEATURE_PLANT_SEEDS_ENABLED=false

# ========================================
# Support hotline
# ========================================
SUPPORT_HOTLINE_WHATSAPP=081200000000
SUPPORT_HOTLINE_PHONE=0317788990

# ========================================
# Crash reporting (Sentry)
# ========================================
SENTRY_DSN_MOBILE=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
