# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sekar_db
POSTGRES_PORT=5432

# Adminer Configuration
ADMINER_PORT=8080

# MinIO Configuration (S3-compatible object storage for local dev)
# These credentials must match AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in be/.env.local.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000              # S3 API
MINIO_CONSOLE_PORT=9001      # web console (http://localhost:9001)
# Bucket the minio-init sidecar creates (match AWS_S3_BUCKET in be/.env.local).
AWS_S3_BUCKET=sekar-media-dev

# Redis Configuration
REDIS_PORT=16379
