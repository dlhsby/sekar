# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sekar_db
POSTGRES_PORT=5432

# Adminer Configuration
ADMINER_PORT=8080

# LocalStack Configuration
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0    # Set to 1 for verbose S3 logs

# Redis Configuration
# Host port mapping (container internal port stays 6379). Defaults to
# 16379 to avoid colliding with a system-installed Redis or another
# project on the dev box. Match this in be/.env's REDIS_URL.
REDIS_PORT=16379
