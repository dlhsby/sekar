{
  "name": "sekar-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "SEKAR — DLH Surabaya worker tracking & task management. Cross-workspace tooling root (Phase 3 onward).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.13.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "tools/eslint-plugin-sekar-design"
  ],
  "scripts": {
    "prepare": "husky",
    "setup": "./scripts/setup.sh",
    "start": "./scripts/start.sh",
    "start:be": "./scripts/start-be.sh",
    "start:web": "./scripts/start-web.sh",
    "start:mobile": "./scripts/start-mobile.sh",
    "stop": "./scripts/stop.sh",
    "infra": "./scripts/infra.sh",
    "infra:status": "./scripts/infra.sh status",
    "infra:down": "./scripts/infra.sh down",
    "tokens:build": "tsx scripts/build-tokens.ts",
    "tokens:verify": "tsx scripts/build-tokens.ts --verify",
    "test:tokens": "jest --config scripts/jest.config.cjs",
    "i18n:check": "node scripts/i18n-parity-check.mjs"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/rule-tester": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
