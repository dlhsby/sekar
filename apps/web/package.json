{
  "name": "web",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -f .env.local -- sh -c 'next dev -p ${WEB_PORT:-3001}'",
    "build": "next build",
    "start": "next start -p ${WEB_PORT:-3001}",
    "env:encrypt": "dotenvx encrypt -f .env.staging -f .env.production",
    "env:decrypt": "dotenvx decrypt -f .env.staging --stdout",
    "env:decrypt:prod": "dotenvx decrypt -f .env.production --stdout",
    "env:get": "dotenvx get --env-file=.env.staging",
    "build:staging": "dotenvx run -f .env.staging -- next build",
    "build:production": "dotenvx run -f .env.production -- next build",
    "start:staging": "dotenvx run -f .env.staging -- next start -p ${WEB_PORT:-3001}",
    "start:production": "dotenvx run -f .env.production -- next start -p ${WEB_PORT:-3001}",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth": "playwright test --project=chromium e2e/01-authentication.spec.ts",
    "test:e2e:quick": "playwright test --project=chromium e2e/01-authentication.spec.ts e2e/02-navigation.spec.ts",
    "type-check": "tsc --noEmit",
    "sw:build": "npx esbuild src/sw/sw.ts --bundle --outfile=public/sw.js --platform=browser --target=chrome90"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-google-maps/api": "^2.20.8",
    "@sentry/nextjs": "^10.59.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@types/supercluster": "^7.1.3",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^15.7.4",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
