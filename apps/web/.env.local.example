# SEKAR Web Dashboard - Local Development Environment
#
# Quick Start:
#   cp .env.local.example .env.local
#   # (Optional) Edit .env.local and add your Google Maps API key
#   npm run dev
#
# All defaults below work out of the box for local development.
# You only need to set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY if you need maps.

# =============================================================================
# API Configuration
# =============================================================================
# Backend API base URL (WITHOUT /api/v1 — the client appends it automatically)
# Make sure the backend is running on http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# API Version (default: v1)
NEXT_PUBLIC_API_VERSION=v1

# WebSocket URL for real-time monitoring updates
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# =============================================================================
# Maps Configuration
# =============================================================================
# Google Maps is the sole map provider — boundary/pin editors, the display
# modal, and the real-time monitoring map. Enable the "Maps JavaScript API" and
# "Geocoding API" on the key. Same key as apps/be/.env GOOGLE_MAPS_API_KEY + the
# mobile app. Build-time (preferred), falling back to the backend's
# GET /config/maps. Optional in dev — leave blank to fall back to the backend
# key (or manual lat/lng inputs if neither is set).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Vector-map Map ID (Google Cloud Console → Map Management). Required for Advanced
# Markers. Build-time (preferred), else the backend's GET /config/maps
# (settings key `maps.map_id`, editable in System Settings). Not a secret.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# =============================================================================
# Application Metadata
# =============================================================================
NEXT_PUBLIC_APP_NAME=SEKAR
NEXT_PUBLIC_APP_VERSION=2.0.0

# =============================================================================
# Feature Flags (Development)
# =============================================================================
# PWA service worker registration (disabled in dev to avoid stale-cache issues)
NEXT_PUBLIC_FEATURE_PWA=false

# Web Push VAPID public key (used by usePushSubscription for admin push).
# Generate a key pair with: npx web-push generate-vapid-keys
# Leave blank in dev to disable push subscription. The matching PRIVATE key
# lives on the backend, never here.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Google Analytics tracking (disabled in dev)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Sentry error reporting (disabled in dev)
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false

# React DevTools and debug tools (enabled in dev)
NEXT_PUBLIC_ENABLE_DEVTOOLS=true

# Verbose logging in console (enable for debugging)
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# =============================================================================
# Analytics (Disabled in Development)
# =============================================================================
# Google Analytics Measurement ID (GA4)
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# =============================================================================
# Error Tracking (Optional for Development)
# =============================================================================
# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/
# Format: https://xxxxx@sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# =============================================================================
# Application Settings
# =============================================================================
# Node environment (automatically set by Next.js, but can be overridden)
NODE_ENV=development

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# Security (Development)
# =============================================================================
# Simple secret for development — NEVER use in production!
SESSION_SECRET=dev-secret-for-local-testing-only

# Set the `secure` flag on auth cookies. Default true; set to false ONLY for
# local HTTP testing (cookies with `secure` are dropped over plain http://).
# Always true in staging/production (served over HTTPS).
NEXT_PUBLIC_SECURE_COOKIES=false

# =============================================================================
# Build Settings (Optional)
# =============================================================================
# Skip type checking during builds (not recommended)
# SKIP_TYPE_CHECK=false

# Skip ESLint during builds (not recommended)
# SKIP_ESLINT=false

# =============================================================================
# Development Tools (Optional)
# =============================================================================
# Enable React Strict Mode (helps identify issues)
# NEXT_PUBLIC_STRICT_MODE=true

# Enable source maps for debugging
# GENERATE_SOURCEMAP=true

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit .env.local to version control
# 2. NEXT_PUBLIC_* variables are exposed to the browser (client-side)
# 3. Non-NEXT_PUBLIC variables are only available server-side
# 4. Restart the dev server after changing variables: npm run dev
# 5. Ensure backend is running on http://localhost:3000 before starting
# 6. Open: http://localhost:3001

# ========================================
# Dev server port
# ========================================
# Read by the dev scripts (scripts/start*.sh) AND by `npm run dev` directly —
# the dev script loads this file via dotenvx, so `next dev -p ${WEB_PORT}` picks
# it up without you having to export it. Change it here when 3001 collides with
# another project on your machine.
WEB_PORT=3001
