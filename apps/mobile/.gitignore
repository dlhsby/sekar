# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
# Environment variables. Plaintext dev files stay private; deploy files
# (.env.staging, .env.production) are committed as dotenvx-ENCRYPTED ciphertext.
# Client keys (Google Maps) are inlined into the bundle anyway, but
# encrypting them keeps them out of plaintext git history. ENCRYPT BEFORE COMMIT.
.env
.env.local
# dotenvx private decryption keys — NEVER commit.
.env.keys
# Decrypted scratch file produced at build time (decrypt-env.js) — never commit.
.env.runtime
.env.*.decrypted
!.env*.example

# Firebase (real service files are secrets — keep only *.example)
android/app/google-services.json
ios/GoogleService-Info.plist
!ios/GoogleService-Info.plist.example

# Serena MCP cache
.serena/
