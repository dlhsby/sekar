<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
      padding: 20px;
    }

    .header {
      background: #1a1a1a;
      color: white;
      padding: 30px 20px;
      margin-bottom: 30px;
      border-radius: 4px;
    }

    .header h1 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 12px;
      opacity: 0.9;
    }

    .section {
      margin-bottom: 30px;
      page-break-inside: avoid;
    }

    .section-title {
      font-size: 16px;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 10px;
      margin-bottom: 15px;
    }

    .kpi-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .kpi-card {
      flex: 1;
      min-width: 120px;
      border: 2px solid #000;
      padding: 15px;
      text-align: center;
    }

    .kpi-value {
      font-size: 22px;
      font-weight: bold;
      color: #1a1a1a;
    }

    .kpi-label {
      font-size: 10px;
      color: #666;
      margin-top: 5px;
    }

    .kpi-trend {
      font-size: 12px;
      margin-top: 5px;
      font-weight: bold;
    }

    .trend-up {
      color: #2ecc71;
    }

    .trend-down {
      color: #e74c3c;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      font-size: 10px;
    }

    th {
      background: #f0f0f0;
      padding: 10px;
      text-align: left;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #e0e0e0;
    }

    tr:nth-child(even) {
      background: #f9f9f9;
    }

    .footer {
      text-align: center;
      font-size: 10px;
      color: #999;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Ringkasan Laporan Bulanan</h1>
    <p>{{month}} {{year}} | Seluruh Sistem</p>
    <p>Dihasilkan: {{generatedAt}}</p>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Eksekutif KPI</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{kpiSummary.attendanceRate}}%</div>
        <div class="kpi-label">Kehadiran</div>
        <div class="kpi-trend {{kpiSummary.attendanceTrend}}">{{kpiSummary.attendanceTrendText}}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{kpiSummary.taskCompletionRate}}%</div>
        <div class="kpi-label">Penyelesaian Tugas</div>
        <div class="kpi-trend {{kpiSummary.taskTrend}}">{{kpiSummary.taskTrendText}}</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{kpiSummary.activityApprovalRate}}%</div>
        <div class="kpi-label">Persetujuan Aktivitas</div>
        <div class="kpi-trend {{kpiSummary.activityTrend}}">{{kpiSummary.activityTrendText}}</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Dashboard KPI (19 Metrik)</div>
    <table>
      <thead>
        <tr>
          <th>KPI</th>
          <th>Nilai</th>
          <th>Target</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {{#each kpis}}
        <tr>
          <td>{{this.name}}</td>
          <td>{{this.value}}</td>
          <td>{{this.target}}</td>
          <td>{{this.status}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Analisis Kehadiran</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceAnalysis.totalWorkerDays}}</div>
        <div class="kpi-label">Hari Kerja Total</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceAnalysis.avgDaily}}%</div>
        <div class="kpi-label">Rata-rata Harian</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceAnalysis.lowestDay}}</div>
        <div class="kpi-label">Hari Terendah</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Analisis Lembur</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{overtimeAnalysis.totalHours}}</div>
        <div class="kpi-label">Total Jam</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">Rp {{overtimeAnalysis.estimatedCost}}</div>
        <div class="kpi-label">Estimasi Biaya</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{overtimeAnalysis.topWorker}}</div>
        <div class="kpi-label">Pekerja Terbanyak</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Perbandingan Rayon</div>
    <table>
      <thead>
        <tr>
          <th>Rayon</th>
          <th>Kehadiran</th>
          <th>Tugas Selesai</th>
          <th>Aktivitas Disetujui</th>
          <th>Skor Kinerja</th>
        </tr>
      </thead>
      <tbody>
        {{#each rayonComparison}}
        <tr>
          <td>{{this.rayonName}}</td>
          <td>{{this.attendance}}%</td>
          <td>{{this.tasksCompleted}}</td>
          <td>{{this.activitiesApproved}}</td>
          <td>{{this.performanceScore}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="footer">
    Ringkasan Laporan Bulanan SEKAR | Dihasilkan pada {{generatedAt}} | Dokumen Resmi DLH Surabaya
  </div>
</body>
</html>
