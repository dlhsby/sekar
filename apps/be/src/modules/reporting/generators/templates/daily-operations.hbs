<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
      background: #fff;
      padding: 20px;
    }

    .page-break {
      page-break-after: always;
    }

    .header {
      background: #1a1a1a;
      color: white;
      padding: 30px 20px;
      margin-bottom: 30px;
      border-radius: 4px;
    }

    .header h1 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 12px;
      opacity: 0.9;
    }

    .section {
      margin-bottom: 30px;
    }

    .section-title {
      font-size: 16px;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 10px;
      margin-bottom: 15px;
    }

    .kpi-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .kpi-card {
      flex: 1;
      min-width: 150px;
      border: 2px solid #000;
      padding: 15px;
      text-align: center;
    }

    .kpi-value {
      font-size: 28px;
      font-weight: bold;
      color: #1a1a1a;
    }

    .kpi-label {
      font-size: 12px;
      color: #666;
      margin-top: 8px;
    }

    .kpi-percentage {
      font-size: 14px;
      font-weight: bold;
      color: #2ecc71;
      margin-top: 5px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      font-size: 11px;
    }

    th {
      background: #f0f0f0;
      padding: 10px;
      text-align: left;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #e0e0e0;
    }

    tr:nth-child(even) {
      background: #f9f9f9;
    }

    .footer {
      text-align: center;
      font-size: 10px;
      color: #999;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Laporan Operasional Harian</h1>
    <p>{{dateRange}} | {{scopeName}}</p>
    <p>Dihasilkan: {{generatedAt}}</p>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Kehadiran</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceSummary.scheduled}}</div>
        <div class="kpi-label">Dijadwalkan</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceSummary.attended}}</div>
        <div class="kpi-label">Hadir</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceSummary.absent}}</div>
        <div class="kpi-label">Tidak Hadir</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceSummary.late}}</div>
        <div class="kpi-label">Terlambat</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{attendanceSummary.attendanceRate}}%</div>
        <div class="kpi-label">Tingkat Kehadiran</div>
        <div class="kpi-percentage">{{attendanceSummary.trend}}</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Tugas</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{taskSummary.new}}</div>
        <div class="kpi-label">Baru</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{taskSummary.completed}}</div>
        <div class="kpi-label">Selesai</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{taskSummary.inProgress}}</div>
        <div class="kpi-label">Sedang Dikerjakan</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{taskSummary.overdue}}</div>
        <div class="kpi-label">Terlewat</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{taskSummary.completionRate}}%</div>
        <div class="kpi-label">Tingkat Penyelesaian</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Aktivitas</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{activitySummary.submitted}}</div>
        <div class="kpi-label">Diajukan</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{activitySummary.approved}}</div>
        <div class="kpi-label">Disetujui</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{activitySummary.rejected}}</div>
        <div class="kpi-label">Ditolak</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{activitySummary.pending}}</div>
        <div class="kpi-label">Menunggu</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{activitySummary.approvalRate}}%</div>
        <div class="kpi-label">Tingkat Persetujuan</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Lembur</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{overtimeSummary.requests}}</div>
        <div class="kpi-label">Permintaan</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{overtimeSummary.approved}}</div>
        <div class="kpi-label">Disetujui</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{overtimeSummary.totalHours}}</div>
        <div class="kpi-label">Total Jam</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Metrik Kunci per Area</div>
    <table>
      <thead>
        <tr>
          <th>Area</th>
          <th>Dijadwalkan</th>
          <th>Hadir</th>
          <th>Tugas Selesai</th>
          <th>Aktivitas Disetujui</th>
        </tr>
      </thead>
      <tbody>
        {{#each areaMetrics}}
        <tr>
          <td>{{this.areaName}}</td>
          <td>{{this.scheduled}}</td>
          <td>{{this.attended}}</td>
          <td>{{this.tasksCompleted}}</td>
          <td>{{this.activitiesApproved}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="footer">
    Laporan Operasional Harian SEKAR | Dihasilkan pada {{generatedAt}} | Dokumen Resmi DLH Surabaya
  </div>
</body>
</html>
