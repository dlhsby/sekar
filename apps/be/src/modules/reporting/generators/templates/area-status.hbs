<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
      padding: 20px;
    }

    .header {
      background: #1a1a1a;
      color: white;
      padding: 30px 20px;
      margin-bottom: 30px;
      border-radius: 4px;
    }

    .header h1 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 12px;
      opacity: 0.9;
    }

    .profile-section {
      background: #f9f9f9;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 4px;
    }

    .profile-row {
      display: flex;
      gap: 20px;
      margin-bottom: 8px;
      font-size: 12px;
    }

    .profile-label {
      font-weight: bold;
      min-width: 120px;
      color: #666;
    }

    .section {
      margin-bottom: 30px;
    }

    .section-title {
      font-size: 16px;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 10px;
      margin-bottom: 15px;
    }

    .kpi-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .kpi-card {
      flex: 1;
      min-width: 150px;
      border: 2px solid #000;
      padding: 15px;
      text-align: center;
    }

    .kpi-value {
      font-size: 24px;
      font-weight: bold;
      color: #1a1a1a;
    }

    .kpi-label {
      font-size: 11px;
      color: #666;
      margin-top: 5px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      font-size: 11px;
    }

    th {
      background: #f0f0f0;
      padding: 10px;
      text-align: left;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #e0e0e0;
    }

    tr:nth-child(even) {
      background: #f9f9f9;
    }

    .footer {
      text-align: center;
      font-size: 10px;
      color: #999;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Laporan Status Area</h1>
    <p>{{period}} | {{generatedAt}}</p>
  </div>

  <div class="profile-section">
    <div class="profile-row">
      <div class="profile-label">Area:</div>
      <div>{{area.name}}</div>
    </div>
    <div class="profile-row">
      <div class="profile-label">Rayon:</div>
      <div>{{area.rayonName}}</div>
    </div>
    <div class="profile-row">
      <div class="profile-label">Koordinat Batas:</div>
      <div>{{area.boundaryCoordinates}}</div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Area</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{areaSummary.currentAssignments}}</div>
        <div class="kpi-label">Penugasan Aktif</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{areaSummary.attendanceRate}}%</div>
        <div class="kpi-label">Kehadiran Rata-rata</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{areaSummary.assetCount}}</div>
        <div class="kpi-label">Aset</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{areaSummary.complianceRate}}%</div>
        <div class="kpi-label">Tingkat Kepatuhan</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Status Tugas</div>
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Jumlah</th>
          <th>Persentase</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Terbuka</td>
          <td>{{taskStatus.open}}</td>
          <td>{{taskStatus.openPercent}}%</td>
        </tr>
        <tr>
          <td>Selesai</td>
          <td>{{taskStatus.completed}}</td>
          <td>{{taskStatus.completedPercent}}%</td>
        </tr>
        <tr>
          <td>Terlewat</td>
          <td>{{taskStatus.overdue}}</td>
          <td>{{taskStatus.overduePercent}}%</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Status Pemeliharaan Aset</div>
    <table>
      <thead>
        <tr>
          <th>Kategori</th>
          <th>Jumlah</th>
          <th>Maintenance Mendatang</th>
          <th>Terlewat</th>
        </tr>
      </thead>
      <tbody>
        {{#each maintenanceStatus}}
        <tr>
          <td>{{this.category}}</td>
          <td>{{this.count}}</td>
          <td>{{this.upcoming}}</td>
          <td>{{this.overdue}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Pekerja Area - Ranking Kinerja</div>
    <table>
      <thead>
        <tr>
          <th>Rank</th>
          <th>Nama</th>
          <th>Kehadiran</th>
          <th>Tugas Selesai</th>
          <th>Skor Kinerja</th>
        </tr>
      </thead>
      <tbody>
        {{#each workerRanking}}
        <tr>
          <td>{{this.rank}}</td>
          <td>{{this.name}}</td>
          <td>{{this.attendance}}%</td>
          <td>{{this.tasksCompleted}}</td>
          <td>{{this.score}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="footer">
    Laporan Status Area SEKAR | Dihasilkan pada {{generatedAt}} | Dokumen Resmi DLH Surabaya
  </div>
</body>
</html>
