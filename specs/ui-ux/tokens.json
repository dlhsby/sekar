{
  "$schema": "./tokens.schema.json",
  "_meta": {
    "version": "1.0.0",
    "lastUpdated": "2026-04-25",
    "source": "specs/ui-ux/design-tokens.md (Layer 1 registry)",
    "notice": "This file is the SINGLE SOURCE OF TRUTH for all Layer 1 design tokens. Any change here requires an ADR. Generated files under fe/web/src/app/generated/ and fe/mobile/src/constants/generated/ are produced from this JSON by scripts/build-tokens.ts — do not edit those by hand."
  },
  "color": {
    "primary":          { "value": "#7FBC8C", "webVar": "--color-nb-primary",         "mobileKey": "nbColors.primary" },
    "primary.hover":    { "value": "#6BA87A", "webVar": "--color-nb-primary-hover",   "mobileKey": "nbColors.primaryHover" },
    "primary.active":   { "value": "#5A9468", "webVar": "--color-nb-primary-active",  "mobileKey": "nbColors.primaryActive" },
    "secondary":        { "value": "#8B7355", "webVar": "--color-nb-secondary",       "mobileKey": "nbColors.secondary" },
    "secondary.hover":  { "value": "#725E45", "webVar": "--color-nb-secondary-hover", "mobileKey": "nbColors.secondaryHover" },
    "success":          { "value": "#7FBC8C", "icon": "check-circle" },
    "success.light":    { "value": "#BAFCA2" },
    "success.dark":     { "value": "#15803D" },
    "warning":          { "value": "#E3A018", "icon": "alert-triangle" },
    "warning.light":    { "value": "#FFDB58" },
    "danger":           { "value": "#FF6B6B", "icon": "x-circle" },
    "danger.light":     { "value": "#FFA07A" },
    "danger.dark":      { "value": "#991B1B" },
    "info":             { "value": "#69D2E7", "icon": "info" },
    "info.light":       { "value": "#A7DBD8" }
  },
  "status": {
    "active":  { "value": "#15803D", "background": "#DCFCE7" },
    "idle":    { "value": "#D97706", "background": "#FEF3C7" },
    "outside": { "value": "#9333EA", "background": "#F3E8FF" },
    "missing": { "value": "#DC2626", "background": "#FEE2E2" },
    "offline": { "value": "#6B7280", "background": "#F3F4F6" }
  },
  "plant": {
    "ok":      { "value": "#15803D", "polygonOpacity": 0.15 },
    "due":     { "value": "#D97706", "polygonOpacity": 0.25 },
    "overdue": { "value": "#DC2626", "polygonOpacity": 0.35 }
  },
  "request": {
    "submitted":    { "value": "#6B7280", "icon": "hourglass" },
    "under_review": { "value": "#2563EB", "icon": "eye" },
    "approved":     { "value": "#15803D", "icon": "check" },
    "rejected":     { "value": "#DC2626", "icon": "x" },
    "converted":    { "value": "#7C3AED", "icon": "arrow-right-circle" },
    "in_progress":  { "value": "#D97706", "icon": "loader" },
    "done":         { "value": "#16A34A", "icon": "check-circle" },
    "cancelled":    { "value": "#9CA3AF", "icon": "ban" }
  },
  "bg": {
    "canvas":        { "value": "#F5F0EB", "usage": "Default app background — warm stone, outdoor-legible" },
    "surface":       { "value": "#FFFFFF", "usage": "Card fill" },
    "accent.yellow": { "value": "#FDFD96", "usage": "Section headers, callouts, hero stripes — NOT a page bg" },
    "accent.mint":   { "value": "#DAF5F0", "usage": "Info banners, tool panels" },
    "accent.green":  { "value": "#B5D2AD", "usage": "Secondary surfaces" },
    "accent.pink":   { "value": "#FCDFFF", "usage": "Elevated cards (modals over modals)" },
    "overlay":       { "value": "rgba(0,0,0,0.5)", "usage": "Modal scrim" }
  },
  "neutral": {
    "black": "#1C1917",
    "white": "#FFFFFF",
    "navy":  "#1A4D2E"
  },
  "gray": {
    "50":  "#FAFAF9",
    "100": "#F5F5F4",
    "200": "#E7E5E4",
    "300": "#D6D3D1",
    "400": "#A8A29E",
    "500": "#78716C",
    "600": "#57534E",
    "700": "#44403C",
    "800": "#292524",
    "900": "#1C1917"
  },
  "sidebar": {
    "bg":     "#1A4D2E",
    "hover":  "#2D5233",
    "active": "#0F3520",
    "fg":     "#FFFFFF",
    "border": "#2D5233"
  },
  "border": {
    "color":        "#1C1917",
    "width.thin":   "1px",
    "width.base":   "2px",
    "width.thick":  "3px",
    "width.extra":  "4px",
    "style":        "solid"
  },
  "radius": {
    "none": "0",
    "sm":   "4px",
    "base": "6px",
    "md":   "8px",
    "lg":   "12px",
    "full": "9999px"
  },
  "shadow": {
    "xs":     { "x": 2,  "y": 2,  "color": "#1C1917", "radius": 0 },
    "sm":     { "x": 4,  "y": 4,  "color": "#1C1917", "radius": 0 },
    "md":     { "x": 6,  "y": 6,  "color": "#1C1917", "radius": 0 },
    "lg":     { "x": 8,  "y": 8,  "color": "#1C1917", "radius": 0 },
    "xl":     { "x": 10, "y": 10, "color": "#1C1917", "radius": 0 },
    "hover":  { "x": 8,  "y": 8,  "color": "#1C1917", "radius": 0 },
    "active": { "x": 2,  "y": 2,  "color": "#1C1917", "radius": 0 },
    "none":   { "x": 0,  "y": 0,  "color": "transparent", "radius": 0 }
  },
  "space": {
    "xs":    "4px",
    "sm":    "8px",
    "md":    "16px",
    "lg":    "24px",
    "xl":    "32px",
    "2xl":   "48px",
    "3xl":   "64px",
    "touch": { "mobile": "48px", "web": "44px" }
  },
  "font": {
    "display": "'Space Grotesk', ui-sans-serif, system-ui, sans-serif",
    "body":    "'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif",
    "mono":    "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace"
  },
  "type": {
    "_note":      "Type scale reconciled with design-tokens.html prototype (Apr 25, 2026). Sizes tightened slightly to match the visual spec — h1 32→28, h2 24→22, h3 20→18, caption weight 600→500.",
    "display-xl": { "font": "display", "weight": 800, "size": 56, "lineHeight": 1.0  },
    "display":    { "font": "display", "weight": 700, "size": 40, "lineHeight": 1.05 },
    "h1":         { "font": "display", "weight": 700, "size": 28, "lineHeight": 1.2  },
    "h2":         { "font": "display", "weight": 600, "size": 22, "lineHeight": 1.3  },
    "h3":         { "font": "display", "weight": 600, "size": 18, "lineHeight": 1.35 },
    "body-lg":    { "font": "body",    "weight": 500, "size": 18, "lineHeight": 1.55 },
    "body":       { "font": "body",    "weight": 400, "size": 16, "lineHeight": 1.5  },
    "body-sm":    { "font": "body",    "weight": 400, "size": 14, "lineHeight": 1.45 },
    "caption":    { "font": "body",    "weight": 500, "size": 12, "lineHeight": 1.4  },
    "mono-sm":    { "font": "mono",    "weight": 500, "size": 12, "lineHeight": 1.4  }
  },
  "motion": {
    "press": { "duration": "100ms", "easing": "ease-out" },
    "hover": { "duration": "150ms", "easing": "ease-out" },
    "enter": { "duration": "200ms", "easing": "ease-out" },
    "exit":  { "duration": "250ms", "easing": "ease-in"  }
  }
}
