# SEKAR Backend — STAGING (AWS) environment template
#
# Staging runs on the shared AWS EC2 host (co-tenant with KPI) behind Caddy, using
# AWS RDS (shared instance, dedicated `sekar_staging` db) and AWS S3 for media.
# See specs/deployment/deployment-guide.md §"AWS staging" and ADR-028.
#
# IMPORTANT — on the live box this file is NOT hand-written. infra/seed-env-from-ssm.sh
# materializes /opt/sekar/.env at deploy time: secrets (DATABASE_PASSWORD, JWT_SECRET,
# JWT_REFRESH_SECRET) are pulled from SSM Parameter Store (/sekar/staging/*, SecureString),
# and S3 uses the EC2 instance role — there are NO AWS access keys on the host. This file
# is the variable catalogue / what a local "staging-like" run would need.

NODE_ENV=staging
PORT=3000

# ===== Database (AWS RDS PostgreSQL — shared instance, dedicated db/role) =====
DATABASE_HOST=kobin-kpi-db.cvuoeguwo5dg.ap-southeast-3.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_USER=sekar
DATABASE_PASSWORD=<from SSM /sekar/staging/DATABASE_PASSWORD>
DATABASE_NAME=sekar_staging
DATABASE_SYNCHRONIZE=false
DATABASE_MIGRATIONS_RUN=false
DATABASE_SSL=true

# ===== Auth =====
JWT_SECRET=<from SSM /sekar/staging/JWT_SECRET>
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=<from SSM /sekar/staging/JWT_REFRESH_SECRET>
JWT_REFRESH_EXPIRATION=7d

# ===== Object storage (real AWS S3 via the EC2 instance role — NO static keys) =====
AWS_REGION=ap-southeast-3
AWS_S3_BUCKET=sekar-media-staging
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY on AWS — the SDK resolves the
# instance role automatically. (Set them only for a local MinIO run, with AWS_ENDPOINT_URL.)

# ===== Redis (in-stack container on the box) =====
REDIS_URL=redis://redis:6379
BULLMQ_PREFIX=sekar-staging

# ===== CORS (public web origin — HTTPS via Caddy auto-HTTPS) =====
CORS_ORIGIN=https://sekar.wahyutrip.com

# ===== Firebase / FCM (disabled until a service account is configured) =====
FCM_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# ===== Observability (optional) =====
SENTRY_ENVIRONMENT=staging
# SENTRY_DSN=<from SSM /sekar/staging/SENTRY_DSN>

# ===== Rate limiting (prod-safe defaults) =====
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_LOGIN_THROTTLE_LIMIT=5
AUTH_LOGIN_THROTTLE_TTL=60000
