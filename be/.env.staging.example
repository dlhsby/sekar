NODE_ENV=staging
PORT=3000

# Database (RDS PostgreSQL)
DATABASE_HOST=sekar-staging-db.xxxxx.ap-southeast-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=<from AWS Secrets Manager>
DATABASE_NAME=sekar_db
DATABASE_SYNCHRONIZE=false
DATABASE_MIGRATIONS_RUN=false
DATABASE_SSL=true

# Auth
JWT_SECRET=<strong-random-256bit-secret>
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=<different-strong-random-256bit>
JWT_REFRESH_EXPIRATION=7d

# AWS (IAM role or access key)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=<IAM role key>
AWS_SECRET_ACCESS_KEY=<IAM role secret>
AWS_S3_BUCKET=sekar-staging-media
# AWS_ENDPOINT_URL=  # Leave empty for real AWS S3
AWS_S3_FORCE_PATH_STYLE=false

# CORS
CORS_ORIGIN=https://staging.sekar.wahyutrip.com

# Firebase / FCM
FCM_ENABLED=true
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Optional
NOTIFICATION_RETRY_ATTEMPTS=3
TASK_AUTO_ASSIGN_ENABLED=false

# Auth login throttle — prod-safe defaults (5 attempts per 60000 ms)
AUTH_LOGIN_THROTTLE_LIMIT=5
AUTH_LOGIN_THROTTLE_TTL=60000
