# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=sekar_db

# Database Behavior Configuration
# IMPORTANT: These control how TypeORM manages your database schema
#
# Two workflows for local development:
#
# OPTION 1: Synchronize Mode (Fast Development)
#   DATABASE_SYNCHRONIZE=true
#   DATABASE_MIGRATIONS_RUN=false
#   → TypeORM auto-creates tables from entities (no migrations needed)
#   → Use this while actively developing features
#
# OPTION 2: Migration Mode (Production-Like Testing)
#   DATABASE_SYNCHRONIZE=false
#   DATABASE_MIGRATIONS_RUN=true
#   → Tables created only via migrations
#   → Use this to test migrations before deploying
#
# Default: Synchronize Mode for convenience
DATABASE_SYNCHRONIZE=true           # Auto-create tables from entities (dev only!)
DATABASE_MIGRATIONS_RUN=false       # Don't auto-run migrations (run manually when testing)
DATABASE_SSL=false                  # SSL connection (false for local, true for RDS)

# Soft-delete safety valve. When NOT 'true', the hard-purge maintenance job
# refuses to permanently delete soft-deleted rows (deleted_at set). Keep unset/
# false everywhere except a deliberate, audited purge run.
ENABLE_HARD_PURGE=false

# NOTE: Before deploying to production, switch to Migration Mode locally
# to test that your migrations work correctly!

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Use strong random secrets in production!
# Generate with: openssl rand -base64 32

# Access token secret (used for login/API requests)
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars
# Access token expiration (short-lived for security)
JWT_EXPIRATION=15m
# Expiry used when minting the access token in AuthService.refresh() (default 15m).
# Usually mirrors JWT_EXPIRATION; set explicitly if the two should differ.
JWT_ACCESS_EXPIRATION=15m

# Refresh token secret (MUST be different from JWT_SECRET!)
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-32chars
# Refresh token expiration (long-lived for convenience)
JWT_REFRESH_EXPIRATION=7d

# ============================================
# AWS S3 CONFIGURATION
# ============================================

# For local development with MinIO (S3-compatible — same engine as production).
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY must match MINIO_ROOT_USER /
# MINIO_ROOT_PASSWORD in infra/.env.
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=sekar-media-dev

# MinIO endpoint (Development Only). The backend's S3InitService auto-creates
# the bucket on boot when NODE_ENV=development and this endpoint is set.
# Backend runs on host: use localhost. Backend in Docker: http://minio:9000.
AWS_ENDPOINT_URL=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true

# Production Configuration
# Remove or comment out AWS_ENDPOINT_URL and AWS_S3_FORCE_PATH_STYLE
# Provide real AWS credentials:
# AWS_ENDPOINT_URL=
# AWS_S3_FORCE_PATH_STYLE=
# AWS_ACCESS_KEY_ID=<your-real-access-key-id>
# AWS_SECRET_ACCESS_KEY=<your-real-secret-access-key>
# AWS_S3_BUCKET=sekar-media-production
#
# S3 Photo URLs: The backend automatically generates presigned URLs (24-hour expiry)
# for photo access. This allows the S3 bucket to remain private while still
# enabling mobile clients to view photos. No additional configuration needed.
#
# S3 Bucket Policy Options:
# 1. Private Bucket + Presigned URLs (RECOMMENDED - implemented)
#    - Bucket has no public access
#    - Backend generates temporary presigned URLs
#    - Most secure option
# 2. Public Read Bucket
#    - Set bucket policy to allow public GetObject
#    - Less secure but simpler URL management
# 3. CloudFront CDN (BEST for production)
#    - Use CloudFront distribution with S3 origin
#    - HTTPS, caching, better performance
#    - Update S3Service.generateUrl() to use CloudFront URL

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3001,http://localhost:19006,http://localhost:8081

# ============================================
# RATE LIMITING
# ============================================
# Global rate limiting (applies to all endpoints)
RATE_LIMIT_TTL=60                   # Time window in seconds
RATE_LIMIT_MAX=100                  # Maximum requests per time window

# Login endpoint rate limiting (stricter to prevent brute force)
RATE_LIMIT_LOGIN_MAX=5              # Maximum login attempts per time window

# ============================================
# SHIFT CONFIGURATION
# ============================================
# Minimum shift duration in minutes before workers can clock out
# Prevents accidental immediate clock-outs and ensures meaningful work periods
# Default: 5 minutes (reasonable for setup/arrival time)
MINIMUM_SHIFT_DURATION_MINUTES=5

# ============================================
# FIREBASE CLOUD MESSAGING (HTTP v1 API)
# ============================================
# Enable/disable Firebase push notifications
FCM_ENABLED=true
# Path to Firebase service account JSON (relative to project root)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# IMPORTANT: Add this file to .gitignore - never commit it to version control!
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Alternative to the JSON file above: supply the three credential fields inline
# (e.g. as platform secrets where mounting a file is awkward). If all three are
# set they take precedence over FIREBASE_SERVICE_ACCOUNT_PATH. Escape newlines in
# the private key as \n. Leave blank to use the service-account file instead.
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# ============================================
# REDIS (Phase 3 — Monitoring v2)
# ============================================
# Dev: host port mapped from the docker-compose Redis is 16379 (avoids
# colliding with a system Redis or another project's Redis on the dev
# box). The container internal port is still 6379. Override here if you
# customized REDIS_PORT in infra/.env. Production uses standard 6379.
REDIS_URL=redis://localhost:16379
REDIS_STREAM_MAX_LEN=100000
STAFFING_DEBOUNCE_SECONDS=30
MONITORING_SWEEP_CRON=*/5 * * * *
CLUSTER_ZOOM_THRESHOLD=14
# A worker whose last GPS fix is older than this is flagged MISSING by the
# monitoring sweep (default 900 s / 15 min).
MISSING_THRESHOLD_SECONDS=900

# ============================================
# PRODUCTION CONFIGURATION EXAMPLE
# ============================================
# Copy this template to create .env.production on your server
#
# NODE_ENV=production
# PORT=3000
#
# # Database (RDS)
# DATABASE_HOST=sekar-db.xxxxx.ap-southeast-3.rds.amazonaws.com
# DATABASE_PORT=5432
# DATABASE_USER=sekar_admin
# DATABASE_PASSWORD=<strong-random-password>
# DATABASE_NAME=sekar_db
# DATABASE_SYNCHRONIZE=true      # Set to TRUE only for INITIAL setup, then change to FALSE!
# DATABASE_MIGRATIONS_RUN=false  # Keep FALSE - run migrations manually
# DATABASE_SSL=true              # Required for RDS
#
# # JWT (Generate with: openssl rand -base64 32)
# JWT_SECRET=<256-bit-random-base64-string>
# JWT_EXPIRATION=15m
# JWT_REFRESH_SECRET=<different-256-bit-random-base64-string>
# JWT_REFRESH_EXPIRATION=7d
#
# # AWS S3 (Production)
# AWS_REGION=ap-southeast-3
# AWS_ACCESS_KEY_ID=<your-production-access-key>
# AWS_SECRET_ACCESS_KEY=<your-production-secret-key>
# AWS_S3_BUCKET=sekar-media-prod
# # Don't set AWS_ENDPOINT_URL or AWS_S3_FORCE_PATH_STYLE for production
# # Photos are served via presigned URLs (24h expiry) - no bucket policy needed
#
# # CORS (Production URLs)
# CORS_ORIGIN=http://sekar.wahyutrip.com,https://sekar.wahyutrip.com
#
# # Rate Limiting
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100
# RATE_LIMIT_LOGIN_MAX=5
#
# # Shift Configuration
# MINIMUM_SHIFT_DURATION_MINUTES=5

# Global rate limit (ThrottlerModule default bucket): max requests per TTL window.
# TTL is in milliseconds. Applies to all routes except those with their own
# throttle (e.g. /auth/login below) or @SkipThrottle (health probes).
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Auth login throttle. Production keeps 5/min for brute-force protection;
# this local-dev template sets a high limit so smoke tests don't hit 429.
AUTH_LOGIN_THROTTLE_LIMIT=1000
AUTH_LOGIN_THROTTLE_TTL=60000

# Phase 4-7 (M3a): tight throttle on /auth/change-password (3/min prod default).
AUTH_CHANGE_PASSWORD_THROTTLE_LIMIT=1000
AUTH_CHANGE_PASSWORD_THROTTLE_TTL=60000

# ─────────────────────────────────────────────────────────────
# Phase 4 sub-phase 4-1 — Production hardening
# ─────────────────────────────────────────────────────────────

# Sentry (backend) — leave empty in development to disable reporting.
# Production: set DSN + release tag matching the deployed git SHA.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# BullMQ — reuses REDIS_URL above. No new infra. Override the queue prefix
# per environment so multiple deployments can share one Redis (e.g. ci/staging).
BULLMQ_PREFIX=sekar-dev
# FCM retry policy for the `fcm-retry` queue: max attempts before giving up,
# and the base delay for BullMQ's exponential backoff between attempts.
BULLMQ_FCM_RETRY_ATTEMPTS=3
BULLMQ_FCM_RETRY_BACKOFF_MS=5000

# Health probes — used by k8s/ECS readiness checks. No env required;
# /health/live and /health/ready are anonymous + throttle-skipped.

# Slow-request thresholds (Phase 4 §B3). A request slower than WARN logs a
# warning; slower than ERROR logs an error. Optional — defaults shown below.
SLOW_REQUEST_WARN_MS=500
SLOW_REQUEST_ERROR_MS=2000

# ============================================
# LOAD TESTING (optional — only for the load-test seed script)
# ============================================
# Used by db:seed:loadtest to generate N satgas accounts named <PREFIX>{1..N}.
# Not needed for normal development.
# LOADTEST_PREFIX=loadtest_satgas
# LOADTEST_USERS=100

# ============================================
# GOOGLE MAPS / GEOCODING (area coordinate enrichment + web master-data maps)
# ============================================
# Google Maps API key. Three consumers share ONE key:
#   1. `npm run seed:geocode` — resolves GPS coordinates for Taman Aktif parks.
#   2. The mobile app (baked at build time) — drop-pin picker + map display.
#   3. The web client — served at RUNTIME via `GET /config/maps` (authenticated),
#      powering the Rayon/Area coordinate drop-pin picker + display modal.
# Enable BOTH the Geocoding API and the Maps JavaScript API on the key. For the
# web (browser) usage, restrict the key by HTTP referrer in dev/prod.
# (The monitoring map still uses Mapbox via the web's NEXT_PUBLIC_MAPBOX_TOKEN.)
# If unset, `seed:geocode` falls back to OpenStreetMap Nominatim and the web
# picker/display degrades to manual lat/lng number inputs.
# GOOGLE_MAPS_API_KEY=
#
# Mapbox token (optional) — only needed if you want the backend to also serve a
# Mapbox token to the web client via GET /config/maps. Normally the web reads its
# own NEXT_PUBLIC_MAPBOX_TOKEN at build time, so this can stay unset.
# MAPBOX_TOKEN=

# ============================================
# GOOGLE SHEETS SYNC — `npm run sheet:sync -- --list` / `sheet:pull` / `sheet:push`
# ============================================
# Two-way sync between the SEKAR input spreadsheet and the seed data.
#
# PREFERRED transport: Apps Script web app (no key — works under the
# iam.disableServiceAccountKeyCreation org policy). Paste scripts/sheet-apps-script.gs
# into the sheet's Apps Script editor, deploy as a Web App (execute as you, access
# "Anyone"), set a shared token, then set:
# SEKAR_SHEET_WEBAPP_URL=
# SEKAR_SHEET_WEBAPP_TOKEN=
#
# FALLBACK transport: service account with Editor access + a downloaded JSON key
# (only if your org allows SA keys). Enable the Google Sheets API on the project.
# GOOGLE_SHEETS_SA_KEYFILE=secrets/sheets-sa.json
#
# SEKAR_SHEET_ID=1WuPIWg2LaKySw2Y53CDgquDLQ3VO-AGGs_kS6exgNq4
