# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist
coverage

# Environment files (use Docker secrets or env vars)
.env
.env.*
!.env.example
# dotenvx-ENCRYPTED staging env is baked into the image (ciphertext; decrypted at
# runtime via DOTENV_PRIVATE_KEY_STAGING). Keep .env.keys / plaintext OUT.
!.env.staging

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Testing
*.spec.ts
*.test.ts
test/
__tests__/

# Documentation
*.md
!README.md
docs/

# Docker files (not needed inside container)
Dockerfile*
docker-compose*
.dockerignore

# Temporary files
tmp/
temp/
*.tmp

# Logs
logs/
*.log
