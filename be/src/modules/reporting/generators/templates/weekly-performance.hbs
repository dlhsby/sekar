<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
      padding: 20px;
    }

    .header {
      background: #1a1a1a;
      color: white;
      padding: 30px 20px;
      margin-bottom: 30px;
      border-radius: 4px;
    }

    .header h1 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 12px;
      opacity: 0.9;
    }

    .section {
      margin-bottom: 30px;
    }

    .section-title {
      font-size: 16px;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 10px;
      margin-bottom: 15px;
    }

    .kpi-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .kpi-card {
      flex: 1;
      min-width: 150px;
      border: 2px solid #000;
      padding: 15px;
      text-align: center;
    }

    .kpi-value {
      font-size: 24px;
      font-weight: bold;
      color: #1a1a1a;
    }

    .kpi-label {
      font-size: 11px;
      color: #666;
      margin-top: 5px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      font-size: 11px;
    }

    th {
      background: #f0f0f0;
      padding: 10px;
      text-align: left;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #e0e0e0;
    }

    tr:nth-child(even) {
      background: #f9f9f9;
    }

    .footer {
      text-align: center;
      font-size: 10px;
      color: #999;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Laporan Kinerja Mingguan</h1>
    <p>Minggu {{weekNumber}} | {{dateRange}} | {{rayonName}}</p>
    <p>Dihasilkan: {{generatedAt}}</p>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Mingguan</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{weeklyMetrics.avgAttendanceRate}}%</div>
        <div class="kpi-label">Rata-rata Kehadiran</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{weeklyMetrics.tasksCompleted}}</div>
        <div class="kpi-label">Tugas Selesai</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{weeklyMetrics.completionRate}}%</div>
        <div class="kpi-label">Tingkat Penyelesaian</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Tren Kehadiran Harian</div>
    <table>
      <thead>
        <tr>
          <th>Hari</th>
          <th>Dijadwalkan</th>
          <th>Hadir</th>
          <th>Tingkat Kehadiran</th>
        </tr>
      </thead>
      <tbody>
        {{#each dailyAttendanceTrend}}
        <tr>
          <td>{{this.date}}</td>
          <td>{{this.scheduled}}</td>
          <td>{{this.attended}}</td>
          <td>{{this.rate}}%</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Top 10 Pekerja Terbaik</div>
    <table>
      <thead>
        <tr>
          <th>Rank</th>
          <th>Nama</th>
          <th>Skor Kinerja</th>
          <th>Kehadiran</th>
          <th>Tugas Selesai</th>
        </tr>
      </thead>
      <tbody>
        {{#each topPerformers}}
        <tr>
          <td>{{this.rank}}</td>
          <td>{{this.name}}</td>
          <td>{{this.score}}</td>
          <td>{{this.attendance}}%</td>
          <td>{{this.tasksCompleted}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Perbandingan Area</div>
    <table>
      <thead>
        <tr>
          <th>Area</th>
          <th>Jumlah Pekerja</th>
          <th>Kehadiran Rata-rata</th>
          <th>Backlog Tugas</th>
        </tr>
      </thead>
      <tbody>
        {{#each areaComparison}}
        <tr>
          <td>{{this.areaName}}</td>
          <td>{{this.workerCount}}</td>
          <td>{{this.avgAttendance}}%</td>
          <td>{{this.taskBacklog}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <div class="footer">
    Laporan Kinerja Mingguan SEKAR | Dihasilkan pada {{generatedAt}} | Dokumen Resmi DLH Surabaya
  </div>
</body>
</html>
