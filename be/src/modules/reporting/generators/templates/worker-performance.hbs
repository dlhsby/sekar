<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
      padding: 20px;
    }

    .header {
      background: #1a1a1a;
      color: white;
      padding: 30px 20px;
      margin-bottom: 30px;
      border-radius: 4px;
    }

    .header h1 {
      font-size: 28px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 12px;
      opacity: 0.9;
    }

    .profile-section {
      background: #f9f9f9;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 4px;
    }

    .profile-row {
      display: flex;
      gap: 20px;
      margin-bottom: 8px;
    }

    .profile-label {
      font-weight: bold;
      min-width: 120px;
      color: #666;
    }

    .section {
      margin-bottom: 30px;
    }

    .section-title {
      font-size: 16px;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 10px;
      margin-bottom: 15px;
    }

    .kpi-container {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .kpi-card {
      flex: 1;
      min-width: 150px;
      border: 2px solid #000;
      padding: 15px;
      text-align: center;
    }

    .kpi-value {
      font-size: 24px;
      font-weight: bold;
      color: #1a1a1a;
    }

    .kpi-label {
      font-size: 11px;
      color: #666;
      margin-top: 5px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      font-size: 11px;
    }

    th {
      background: #f0f0f0;
      padding: 10px;
      text-align: left;
      font-weight: bold;
      border-bottom: 2px solid #1a1a1a;
    }

    td {
      padding: 10px;
      border-bottom: 1px solid #e0e0e0;
    }

    tr:nth-child(even) {
      background: #f9f9f9;
    }

    .footer {
      text-align: center;
      font-size: 10px;
      color: #999;
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Laporan Kinerja Pekerja</h1>
    <p>{{period}} | {{generatedAt}}</p>
  </div>

  <div class="profile-section">
    <div class="profile-row">
      <div class="profile-label">Nama:</div>
      <div>{{worker.fullName}}</div>
    </div>
    <div class="profile-row">
      <div class="profile-label">Peran:</div>
      <div>{{worker.role}}</div>
    </div>
    <div class="profile-row">
      <div class="profile-label">Area:</div>
      <div>{{worker.areaName}}</div>
    </div>
    <div class="profile-row">
      <div class="profile-label">Rayon:</div>
      <div>{{worker.rayonName}}</div>
    </div>
    <div class="profile-row">
      <div class="profile-label">ID Pegawai:</div>
      <div>{{worker.employeeId}}</div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Ringkasan Kinerja</div>
    <div class="kpi-container">
      <div class="kpi-card">
        <div class="kpi-value">{{performanceSummary.attendanceRate}}%</div>
        <div class="kpi-label">Kehadiran</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{performanceSummary.punctualityScore}}</div>
        <div class="kpi-label">Skor Ketepatan</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{performanceSummary.taskCompletionRate}}%</div>
        <div class="kpi-label">Penyelesaian Tugas</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{performanceSummary.activityApprovalRate}}%</div>
        <div class="kpi-label">Persetujuan Aktivitas</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-value">{{performanceSummary.overallScore}}</div>
        <div class="kpi-label">Skor Keseluruhan</div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Kehadiran</div>
    <table>
      <thead>
        <tr>
          <th>Metrik</th>
          <th>Nilai</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Total Hari Kerja</td>
          <td>{{attendance.totalWorkDays}}</td>
        </tr>
        <tr>
          <td>Hadir</td>
          <td>{{attendance.present}}</td>
        </tr>
        <tr>
          <td>Tidak Hadir</td>
          <td>{{attendance.absent}}</td>
        </tr>
        <tr>
          <td>Terlambat</td>
          <td>{{attendance.late}} (rata-rata {{attendance.avgLateMinutes}} menit)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Kinerja Tugas</div>
    <table>
      <thead>
        <tr>
          <th>Metrik</th>
          <th>Nilai</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Tugas Ditugaskan</td>
          <td>{{taskPerformance.assigned}}</td>
        </tr>
        <tr>
          <td>Tugas Selesai</td>
          <td>{{taskPerformance.completed}}</td>
        </tr>
        <tr>
          <td>Durasi Rata-rata Penyelesaian</td>
          <td>{{taskPerformance.avgDurationHours}} jam</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Kinerja Aktivitas</div>
    <table>
      <thead>
        <tr>
          <th>Metrik</th>
          <th>Nilai</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Aktivitas Diajukan</td>
          <td>{{activityPerformance.submitted}}</td>
        </tr>
        <tr>
          <td>Aktivitas Disetujui</td>
          <td>{{activityPerformance.approved}}</td>
        </tr>
        <tr>
          <td>Aktivitas Ditolak</td>
          <td>{{activityPerformance.rejected}}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <div class="section-title">Catatan Kinerja</div>
    <p>{{performanceNotes}}</p>
  </div>

  <div class="footer">
    Laporan Kinerja Pekerja SEKAR | Dihasilkan pada {{generatedAt}} | Dokumen Resmi DLH Surabaya
  </div>
</body>
</html>
