{
  "name": "sekar-backend",
  "version": "0.1.0",
  "description": "SEKAR Backend API - Worker tracking and task management system",
  "author": "DLH Surabaya",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.13.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "env:encrypt": "dotenvx encrypt -f .env.staging",
    "env:decrypt": "dotenvx decrypt -f .env.staging --stdout",
    "env:get": "dotenvx get --env-file=.env.staging",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "db:seed": "npm run db:seed:phase1 && npm run db:seed:phase2 && npm run db:seed:phase3 && npm run db:seed:notifications",
    "db:seed:phase1": "ts-node -r tsconfig-paths/register src/database/seeds/seed-phase1.ts",
    "db:seed:phase2": "ts-node -r tsconfig-paths/register src/database/seeds/seed-phase2.ts",
    "db:seed:phase3": "ts-node -r tsconfig-paths/register src/database/seeds/seed-phase3.ts",
    "db:seed:notifications": "ts-node -r tsconfig-paths/register src/database/seeds/seed-notifications.ts",
    "db:seed:monitoring-demo": "ts-node -r tsconfig-paths/register src/database/seeds/seed-monitoring-demo.ts",
    "db:seed:reference": "ts-node -r tsconfig-paths/register src/database/seeds/seed-reference.ts",
    "db:seed:staging": "ts-node -r tsconfig-paths/register src/database/seeds/seed-staging.ts",
    "db:seed:staging:prod": "node dist/src/database/seeds/seed-staging.js",
    "db:seed:production": "ts-node -r tsconfig-paths/register src/database/seeds/seed-production.ts",
    "db:seed:production:prod": "node dist/src/database/seeds/seed-production.js",
    "db:seed:loadtest": "ts-node -r tsconfig-paths/register src/database/seeds/seed-loadtest.ts",
    "db:reset": "npm run db:seed",
    "db:fix-orphans": "ts-node -r tsconfig-paths/register src/database/seeds/db-fix-orphans.ts",
    "db:seed:prod": "node dist/src/database/seeds/seed-reference.js",
    "db:seed:phase1:prod": "node dist/src/database/seeds/seed-phase1.js",
    "db:seed:phase2:prod": "node dist/src/database/seeds/seed-phase2.js",
    "db:seed:phase3:prod": "node dist/src/database/seeds/seed-phase3.js",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/src/database/data-source.js",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "migration:revert:prod": "node ./node_modules/typeorm/cli.js migration:revert -d dist/src/database/data-source.js",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/database/data-source.ts",
    "migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create",
    "migration:show": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d src/database/data-source.ts",
    "migration:show:prod": "node ./node_modules/typeorm/cli.js migration:show -d dist/src/database/data-source.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:cov": "jest --coverage --forceExit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@dotenvx/dotenvx": "^1.73.1",
    "@eslint/eslintrc": "^3.3.5",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^11.1.26",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/geojson": "^7946.0.16",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "exceljs": "^4.4.0",
    "firebase-admin": "^14.0.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.30",
    "uuid": "^14.0.0",
    "xml2js": "^0.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.13.2",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@nestjs/swagger": {
      "js-yaml": "^4.2.0"
    },
    "uuid": "^14.0.0",
    "lodash": "^4.17.21",
    "tar": "^7.5.10",
    "fast-xml-parser": "^5.3.8",
    "serialize-javascript": "^7.0.3",
    "multer": "^2.1.1",
    "http-proxy-agent": "^7.0.0",
    "@mapbox/node-pre-gyp": {
      "tar": "^7.5.10"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!uuid)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/seed-*.ts",
      "!**/config/firebase.config.ts",
      "!**/*.interface.ts",
      "!**/entities/*.entity.ts",
      "!**/dto/*.dto.ts",
      "!**/dto/index.ts",
      "!**/decorators/*.decorator.ts",
      "!**/database/data-source.ts",
      "!**/database/migrations/*.ts",
      "!**/database/backfill/*.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 79,
        "functions": 75,
        "lines": 85,
        "statements": 85
      }
    }
  }
}
