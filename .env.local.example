# SEKAR dev ports — single source of truth for the dev scripts.
# scripts/*.sh source this file (when copied to .env.local) and EXPORT the
# values, so backend + web inherit them regardless of their own .env files
# (a real exported env var beats anything Nest/Next read from disk).
#
# Copy to .env.local and adjust when the defaults collide with other projects
# on your machine (e.g. BE_PORT=3002 / WEB_PORT=3003). .env.local is
# gitignored — per-machine only.
#
# Pattern borrowed from the SWAT monorepo's scripts/start.sh.

# Backend (NestJS) — exported to the backend process as PORT.
BE_PORT=3000

# Web (Next.js) — consumed by fe/web's `next dev -p ${WEB_PORT:-3001}`.
WEB_PORT=3001
