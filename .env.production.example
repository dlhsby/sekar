# SEKAR — Production environment for docker-compose.prod.yml
#
#   cp .env.production.example .env.production   # then fill in EVERY <...> value
#
# This single file drives the whole stack:
#   - the `backend` service loads it via env_file (all backend runtime vars),
#   - the postgres / minio services read DATABASE_* / AWS_* for provisioning,
#   - the `web` build reads NEXT_PUBLIC_* as build args.
# .env.production is gitignored — NEVER commit real secrets. Generate strong
# secrets with: openssl rand -base64 32

# ===== Core =====
NODE_ENV=production
PORT=3000

# ===== Database =====
# Used both by the backend (DATABASE_*) and to provision the postgres service.
# DATABASE_HOST/PORT are overridden to the compose service in the compose file.
DATABASE_USER=sekar_admin
DATABASE_PASSWORD=<strong-db-password>
DATABASE_NAME=sekar_db
DATABASE_SYNCHRONIZE=false        # NEVER true in production — migrations only
DATABASE_MIGRATIONS_RUN=false     # run `npm run migration:run` explicitly
DATABASE_SSL=false                # true if using a managed DB that requires TLS

# ===== JWT =====
JWT_SECRET=<openssl rand -base64 32>
JWT_EXPIRATION=15m
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=<different openssl rand -base64 32>
JWT_REFRESH_EXPIRATION=7d

# ===== Object storage (MinIO in-stack, or real AWS S3) =====
# For the in-stack MinIO these double as the MinIO root credentials.
# For real S3: set real IAM creds + region, and REMOVE the AWS_ENDPOINT_URL /
# AWS_S3_FORCE_PATH_STYLE overrides from docker-compose.prod.yml.
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=<access-key-or-minio-user>
AWS_SECRET_ACCESS_KEY=<secret-key-or-minio-password>
AWS_S3_BUCKET=sekar-media
# AWS_ENDPOINT_URL / AWS_S3_FORCE_PATH_STYLE are set in the compose file for MinIO.

# ===== CORS =====
# The public origin(s) the web dashboard is served from.
CORS_ORIGIN=https://sekar.example.com

# ===== Rate limiting =====
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_LOGIN_THROTTLE_LIMIT=5
AUTH_LOGIN_THROTTLE_TTL=60000
AUTH_CHANGE_PASSWORD_THROTTLE_LIMIT=3
AUTH_CHANGE_PASSWORD_THROTTLE_TTL=60000

# ===== Firebase Cloud Messaging =====
# Either mount a service-account JSON and set FIREBASE_SERVICE_ACCOUNT_PATH,
# or supply the three inline fields. Leave FCM_ENABLED=false until configured.
FCM_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# ===== Redis (set to the in-stack service; overridden in compose) =====
REDIS_URL=redis://redis:6379
REDIS_STREAM_MAX_LEN=100000
STAFFING_DEBOUNCE_SECONDS=30
MONITORING_SWEEP_CRON=*/5 * * * *
CLUSTER_ZOOM_THRESHOLD=14
MISSING_THRESHOLD_SECONDS=900

# ===== Sentry (optional) =====
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== BullMQ =====
BULLMQ_PREFIX=sekar-prod
BULLMQ_FCM_RETRY_ATTEMPTS=3
BULLMQ_FCM_RETRY_BACKOFF_MS=5000

# ===== Shift config =====
MINIMUM_SHIFT_DURATION_MINUTES=5

# ===== Web build args (baked into the browser bundle at build time) =====
# These are the PUBLIC URLs the browser hits (through Nginx), NOT service names.
NEXT_PUBLIC_API_URL=https://sekar.example.com
NEXT_PUBLIC_WS_URL=wss://sekar.example.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<google-maps-key>
