logs/

# Environment files. Plaintext dev files stay private; deploy files (.env.staging,
# .env.production) are committed as dotenvx-ENCRYPTED ciphertext (secrets are
# `encrypted:…`, safe in git). See specs/deployment/encrypted-secrets.md.
.env
.env.local
.env.development
# dotenvx private decryption keys — NEVER commit (this is the one real secret).
.env.keys
# Decrypted scratch files produced at build time — never commit.
.env.*.decrypted
.env.runtime
!.env*.example

# TLS certificates for the production Nginx (mounted into the container)
infra/certs/

# Infrastructure data (persistent volumes)
infra/data/
infra/localstack/

# Root-level npm workspaces (Phase 3 onward — see ADR-036)
/node_modules/

# Per-session scratch prompts / planning notes — not part of the repo
prompts/


# WSL/Windows alternate-data-stream junk (sit next to downloaded creds)
*:Zone.Identifier
